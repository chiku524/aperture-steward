# =============================================================
# Nosana x ElizaOS Agent Challenge — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# -------------------------------------------------------------
# LLM Configuration — Qwen3.5-9B via Nosana Inference Endpoint
# -------------------------------------------------------------
# Chat/completions base URL and model id are assigned by Nosana (support may rotate them).
# Use GET {OPENAI_BASE_URL}/models to list available model ids.

OPENAI_API_KEY=nosana
OPENAI_BASE_URL=https://5i8frj7ann99bbw9gzpprvzj2esugg39hxbb4unypskq.node.k8s.prd.nos.ci/v1

# Model id from GET .../v1/models (must match the served id).
# @elizaos/plugin-openai uses OPENAI_LARGE_MODEL / OPENAI_SMALL_MODEL for chat (defaults to gpt-4o / gpt-4o-mini if unset).
MODEL_NAME=Qwen3.5-9B-FP8
OPENAI_SMALL_MODEL=Qwen3.5-9B-FP8
OPENAI_LARGE_MODEL=Qwen3.5-9B-FP8

# Steward tuning (read by custom provider + decision artifacts)
ATTENTION_BUDGET_LEVEL=normal
SOVEREIGNTY_MODE=strict

# Steward HTTP API limits (optional)
# STEWARD_MAX_MESSAGE_CHARS=12000
# STEWARD_CHAT_TIMEOUT_MS=120000

# -------------------------------------------------------------
# Embedding Configuration — via Nosana Inference Endpoint
# -------------------------------------------------------------
OPENAI_EMBEDDING_URL=https://4yiccatpyxx773jtewo5ccwhw1s2hezq5pehndb6fcfq.node.k8s.prd.nos.ci/v1
OPENAI_EMBEDDING_API_KEY=nosana
OPENAI_EMBEDDING_MODEL=Qwen3-Embedding-0.6B
OPENAI_EMBEDDING_DIMENSIONS=1024

# -------------------------------------------------------------
# Option B: Local development with Ollama (optional)
# -------------------------------------------------------------
# Install Ollama: https://ollama.com/download
# Then run: ollama pull qwen3.5:27b && ollama serve
#
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# MODEL_NAME=qwen3.5:27b

# -------------------------------------------------------------
# Nosana Deploy API (optional — for scripts/nosana-deployment.mjs only)
# -------------------------------------------------------------
# Create at https://deploy.nosana.com/account/ — never commit the real key.
# NOSANA_API_KEY=nos_...

# -------------------------------------------------------------
# Agent Server Configuration
# -------------------------------------------------------------
SERVER_PORT=3000

# -------------------------------------------------------------
# Database (SQLite — sufficient for development)
# -------------------------------------------------------------
# Default: ./data/db.sqlite (created automatically)
# For production, consider a persistent storage solution.
# SQLITE_DATA_DIR=./data

# -------------------------------------------------------------
# Optional: Social Integrations (add plugins as needed)
# -------------------------------------------------------------
# Telegram bot — https://core.telegram.org/bots#creating-a-new-bot
# TELEGRAM_BOT_TOKEN=

# Discord bot — https://discord.com/developers/applications
# DISCORD_API_TOKEN=

# Twitter/X — https://developer.twitter.com
# TWITTER_USERNAME=
# TWITTER_PASSWORD=
# TWITTER_EMAIL=
